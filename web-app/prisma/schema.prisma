generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String              @id @default(cuid())
  privyId            String              @unique
  email              String?             @unique
  walletAddress      String?             @unique
  firstName          String?
  lastName           String?
  userName           String?
  avatar             String?
  signupDate         DateTime            @default(now())
  lastActivity       DateTime            @updatedAt
  submissionsCount   Int                 @default(0)
  commentsCount      Int                 @default(0)
  votesGivenCount    Int                 @default(0)
  votesReceivedCount Int                 @default(0)
  affiliation        String?
  birthYear          Int?
  guild              String?
  profileComplete    Boolean             @default(false)
  calibration_scores calibration_scores?
  comments           Comment[]
  guild_memberships  guild_memberships[]
  submissions        Submission[]
  user_activity      user_activity?
  votes              Vote[]

  @@map("users")
}

model Submission {
  id                       String                   @id @default(cuid())
  title                    String
  overview                 String
  sourceLink               String?
  createdAt                DateTime                 @default(now())
  updatedAt                DateTime                 @updatedAt
  submitterId              String
  clarificationsExtensions ClarificationExtension[]
  comments                 Comment[]
  directlyAddressedDPs     DirectlyAddressedDP[]
  quality_scores           quality_scores?
  submitter                User                     @relation(fields: [submitterId], references: [id], onDelete: Cascade)
  votes                    Vote[]

  @@map("submissions")
}

model DirectlyAddressedDP {
  id           String     @id @default(cuid())
  dp           String
  summary      String
  submissionId String
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@map("directly_addressed_dps")
}

model ClarificationExtension {
  id           String     @id @default(cuid())
  dp           String
  type         String
  title        String
  content      String
  whyItMatters String
  submissionId String
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@map("clarifications_extensions")
}

model Comment {
  id           String     @id @default(cuid())
  content      String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  authorId     String
  submissionId String
  elementId    String?
  elementType  String?
  author       User       @relation(fields: [authorId], references: [id], onDelete: Cascade)
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  votes        Vote[]

  @@map("comments")
}

model Vote {
  id           String      @id @default(cuid())
  type         VoteType
  createdAt    DateTime    @default(now())
  voterId      String
  commentId    String?
  submissionId String?
  elementId    String?
  elementType  String?
  comment      Comment?    @relation(fields: [commentId], references: [id], onDelete: Cascade)
  submission   Submission? @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  voter        User        @relation(fields: [voterId], references: [id], onDelete: Cascade)

  @@unique([voterId, commentId])
  @@unique([voterId, elementId, elementType, submissionId])
  @@map("votes")
}

model calibration_scores {
  id          String   @id
  userId      String   @unique
  accuracy    Float
  consistency Float
  helpfulness Float
  bonus       Int
  lastUpdated DateTime @default(now())
  createdAt   DateTime @default(now())
  users       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model guild_memberships {
  id       String   @id
  guildId  String
  userId   String
  joinedAt DateTime @default(now())
  guilds   guilds   @relation(fields: [guildId], references: [id], onDelete: Cascade)
  users    User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([guildId, userId])
}

model guilds {
  id                String              @id
  name              String              @unique
  description       String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime
  guild_memberships guild_memberships[]
}

model quality_scores {
  id           String     @id
  submissionId String     @unique
  relevance    Int
  substance    Int
  novelty      Int
  civility     Int
  overall      Int
  modelVersion String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime
  submissions  Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
}

model user_activity {
  id           String    @id
  userId       String    @unique
  submissions  Int       @default(0)
  comments     Int       @default(0)
  votes        Int       @default(0)
  dailyVotes   Int       @default(0)
  lastActivity DateTime  @default(now())
  lastVoteDate DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime
  users        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model vote_consensus {
  id             String   @id
  targetId       String
  targetType     String
  consensusScore Float
  totalVotes     Int
  positiveVotes  Int
  negativeVotes  Int
  calculatedAt   DateTime @default(now())
  updatedAt      DateTime

  @@unique([targetId, targetType])
}

enum VoteType {
  UP
  DOWN
}
